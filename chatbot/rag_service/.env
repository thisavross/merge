# Moodle Chatbot RAG — local environment (MAMP)
# Password dengan *, #, dll. wajib pakai tanda kutip: MYSQL_PASSWORD="..."

# ── MySQL (same DB as Moodle config.php) ─────────────────────────────────────
# MAMP: pakai socket jika TCP gagal — cek path: ls /Applications/MAMP/tmp/mysql/
# MYSQL_UNIX_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD="itudia12*"
# MYSQL_DATABASE=moodle500
# MYSQL_PREFIX=mdl_
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
#MYSQL_PASSWORD="itudia12*"
MYSQL_PASSWORD=
MYSQL_DATABASE=moodle500
MYSQL_PREFIX=mdl_
# ── Moodle dataroot ($CFG->dataroot) ──────────────────────────────────────────
MOODLE_DATAROOT=/moodle/dataroot
MOODLE_DATAROOT_HOST=C:/xampp/moodledata
CHROMA_HOST_PORT=8000
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_DB_URL=http://chromadb:8000
CHROMA_PERSIST_DIR=/app/local/chatbot/rag_service/chroma_db
CHROMA_COLLECTION_NAME=
# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_CHAT_MODEL=qwen3_q4km:latest
OLLAMA_VISION_MODEL=qwen25vl-ctx:latest

OLLAMA_CHAT_TEMPERATURE=0.25

# OLLAMA_CHAT_NUM_CTX=16384
# OLLAMA_CHAT_NUM_PREDICT=4096
# OLLAMA_QUIZ_NUM_PREDICT=12288

# OLLAMA_CHAT_NUM_CTX=6144
# OLLAMA_CHAT_NUM_PREDICT=1536
OLLAMA_CHAT_NUM_CTX=4096
OLLAMA_CHAT_NUM_PREDICT=512
OLLAMA_QUIZ_NUM_PREDICT=2560

QUIZ_TOKENS_PER_QUESTION=400
OLLAMA_NUM_THREAD=4

# ── RAG / chunking ───────────────────────────────────────────────────────────
CHUNK_SIZE=600
MAX_CHUNKS=15
TOP_K=3

#---module ocr
DOC_COLLECTION=rag_documents
CHUNK_COLLECTION=rag_chunks

DOC_RETRIEVAL_K=5
CHUNK_RETRIEVAL_K=30
FINAL_TOP_K=5
OLLAMA_VISION_MODEL=qwen25vl-ctx:latest
MAX_CONTEXT_CHARS=6000

table_detector = YOLO("ocr/model/table_det.pt")
#-----
MOODLE_CHAT_COLLECTION=moodle_chat
MOODLE_COURSE_COLLECTION=moodle_course

SUMMARIZE_CONTEXT_CHUNKS=6
SUMMARIZE_MAX_CONTEXT_TOKENS=600
OLLAMA_SUMMARIZE_NUM_PREDICT=300

# ── MinIO (Sinarmas / PDF knowledge) ─────────────────────────────────────────
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smart-knowledge
MINIO_SECURE=false

# ── Redis (history + semantic cache) ─────────────────────────────────────────
# Format: redis://[:password@]host:port/db
#REDIS_URL=redis://127.0.0.1:6379/0
REDIS_URL=redis://127.0.0.1:6380/0
REDIS_HISTORY_TTL=86400
REDIS_CACHE_TTL=3600
# REDIS_MAX_HISTORY_TURNS=40
REDIS_MAX_HISTORY_TURNS=20
REDIS_MAX_CACHE_ENTRIES=200
REDIS_EMBED_CACHE_TTL=3600
REDIS_COURSE_META_TTL=86400
REDIS_SUMMARY_CACHE_TTL=43200  # 12 jam

# Semantic cache + retrieval tuning
# SEMANTIC_CACHE_THRESHOLD=0.90
SEMANTIC_CACHE_THRESHOLD=0.88

# Adaptive-k retrieval (Taguchi et al.) — cut chunks at largest similarity gap
ADAPTIVE_K_ENABLED=true
ADAPTIVE_K_MAX_MULTIPLIER=3
ADAPTIVE_K_MIN_GAP=0.05
CROSS_COURSE_SEARCH_MAX=12
GLOBAL_LAZY_INDEX_MAX=2
BACKGROUND_COURSE_INDEX=true
EMBED_CACHE_ENABLED=true

# ── Security (optional — match Moodle plugin Shared secret) ───────────────────
# CHATBOT_SECRET=

