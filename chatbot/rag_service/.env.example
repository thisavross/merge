# Copy to .env and adjust for your MAMP MySQL (same DB as Moodle).
# Use either TCP (MYSQL_HOST + MYSQL_PORT) OR socket (MYSQL_UNIX_SOCKET), not both needed.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=moodle
MYSQL_PASSWORD=moodle
MYSQL_DATABASE=moodle500
MYSQL_PREFIX=mdl_
# MAMP (typical): uncomment and set if TCP login fails but Moodle works:
# MYSQL_UNIX_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock

# Moodle dataroot used to read stored files from moodledata/filedir (Moodle's $CFG->dataroot).
MOODLE_DATAROOT=

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2
# If empty, the chat model is used. Set e.g. llava for image attachments (vision).
OLLAMA_VISION_MODEL=

CHUNK_SIZE=800
MAX_CHUNKS=40
TOP_K=5

# Optional: must match Moodle plugin "Shared secret" (header X-Chatbot-Secret)
CHATBOT_SECRET=

# Pydantic also accepts these names (case-insensitive):
# chatbot_secret=
