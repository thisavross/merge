# Copy to local/chatbot/docker/.env and adjust for your machine.
# cp local/chatbot/docker/.env.example local/chatbot/docker/.env

# ── Published ports (host) ────────────────────────────────────────────────────
RAG_HOST_PORT=8787
# Host port (container RAG tetap pakai redis:6379). Pakai 6380 jika 6379 sudah dipakai Redis lokal.
REDIS_HOST_PORT=6380
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
OLLAMA_HOST_PORT=11434

# ── MySQL (Moodle on host — MAMP) ─────────────────────────────────────────────
# Use host.docker.internal on Docker Desktop (Mac/Windows). Linux: same or host IP.
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=moodle500
MYSQL_PREFIX=mdl_
MYSQL_UNIX_SOCKET=

# Absolute path on the HOST to Moodle dataroot (mounted read-only into RAG)
MOODLE_DATAROOT_HOST=/Applications/MAMP/data/moodle500
MOODLE_DATAROOT=/moodle/dataroot

# ── Ollama models (must match what you pull) ──────────────────────────────────
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_CHAT_MODEL=qwen3_q4km:latest
OLLAMA_VISION_MODEL=glm-ocr:q8_0

# ── MinIO (must match minio-init bucket name) ─────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smart-knowledge
MINIO_SECURE=false

# ── RAG / chunking (optional — defaults in config.py) ─────────────────────────
TOP_K=3
MAX_CHUNKS=15
CHUNK_SIZE=600
OLLAMA_CHAT_TEMPERATURE=0.2
# Docker: jangan 16384 kecuali RAM Docker Desktop ≥ 8GB (risiko OOM)
OLLAMA_CHAT_NUM_CTX=6144
OLLAMA_CHAT_NUM_PREDICT=1536
OLLAMA_QUIZ_NUM_PREDICT=2560
MOODLE_CHAT_COLLECTION=moodle_chat
MOODLE_COURSE_COLLECTION=moodle_course

# ── Redis TTL ─────────────────────────────────────────────────────────────────
REDIS_HISTORY_TTL=86400
REDIS_CACHE_TTL=3600
REDIS_MAX_HISTORY_TURNS=40
REDIS_MAX_CACHE_ENTRIES=200

# ── Moodle plugin shared secret (optional) ────────────────────────────────────
CHATBOT_SECRET=
